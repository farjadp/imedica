{
  "name": "@imedica/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared types, Zod validators, and constants for the Imedica monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./validators": "./dist/validators/index.js",
    "./constants": "./dist/constants/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@imedica/config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
