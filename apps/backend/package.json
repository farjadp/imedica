{
  "name": "@imedica/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Imedica backend API — Express + Prisma + TypeScript",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx --yes dotenv-cli -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "npx --yes dotenv-cli -e ../../.env -- prisma migrate dev --schema src/db/prisma/schema.prisma",
    "db:migrate:prod": "npx --yes dotenv-cli -e ../../.env -- prisma migrate deploy --schema src/db/prisma/schema.prisma",
    "db:generate": "npx --yes dotenv-cli -e ../../.env -- prisma generate --schema src/db/prisma/schema.prisma",
    "db:seed": "npx --yes dotenv-cli -e ../../.env -- tsx src/db/seeds/seed.ts",
    "db:studio": "npx --yes dotenv-cli -e ../../.env -- prisma studio --schema src/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@imedica/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@imedica/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.4",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.4"
  }
}
