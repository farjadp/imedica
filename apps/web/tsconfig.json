{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@imedica/shared": ["../../packages/shared/src/index.ts"],
      "@imedica/shared/*": ["../../packages/shared/src/*"],
      "@/*": ["src/*"]
    },
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
