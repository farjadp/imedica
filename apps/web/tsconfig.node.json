{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@imedica/shared": ["../../packages/shared/src/index.ts"],
      "@imedica/shared/*": ["../../packages/shared/src/*"]
    },
    "noEmit": true
  },
  "include": ["vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
