# ============================================================================
# File: .env.example
# Version: 1.0.0 — 2026-04-20
# Why: Documents every required env var with explanations. Copy to .env and
#      fill in real values. NEVER commit .env — only .env.example.
# Env / Identity: All environments (local, staging, production)
# ============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# The public base URL of the app (used in email links)
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# ─── Database (Single PostgreSQL — 3 schemas: identity, analytics, content) ──
# IMPORTANT: All production databases MUST reside in DigitalOcean Toronto (TOR1)
# for PIPEDA/PHIPA Canadian data residency compliance.
DATABASE_URL=postgresql://imedica:imedica_dev_password@localhost:5432/imedica

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# ROTATE THESE before any deployment — these placeholders are not secure.
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Access token lifetime (default 15 minutes)
JWT_ACCESS_EXPIRES_IN=900
# Refresh token lifetime (default 7 days)
JWT_REFRESH_EXPIRES_IN=604800

# ─── De-identification Service ───────────────────────────────────────────────
# Used as HMAC-SHA256 key to generate anonymous_hash from user_id.
# MUST be rotated before production. Changing this invalidates all existing mappings.
# Generate with: openssl rand -hex 64
DEIDENT_SECRET=CHANGE_ME_deident_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email (Mailhog for local dev, SendGrid for production) ──────────────────
EMAIL_FROM=noreply@imedica.ca
EMAIL_FROM_NAME=Imedica

# Mailhog (local dev) — runs on port 1025 (SMTP) and 8025 (web UI)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SendGrid (production)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic Claude API ────────────────────────────────────────────────────
# Used for LLM-enhanced feedback (Phase 5). Not needed in Phase 1.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1000
ANTHROPIC_TIMEOUT_MS=5000

# ─── Sentry Error Tracking ───────────────────────────────────────────────────
# Can be left empty in local dev (errors will just log to console)
# SENTRY_DSN=https://xxxxxxxxxx@oxxxxxxxxx.ingest.sentry.io/xxxxxxxxxx

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# For media/file storage (Phase 3+)
# CF_R2_ACCOUNT_ID=
# CF_R2_ACCESS_KEY_ID=
# CF_R2_SECRET_ACCESS_KEY=
# CF_R2_BUCKET_NAME=

# ─── PostHog Analytics (self-hosted) ─────────────────────────────────────────
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://analytics.imedica.ca

# ─── LLM Cost Alerting ───────────────────────────────────────────────────────
# Monthly spend alert threshold in USD (Phase 5)
# LLM_MONTHLY_BUDGET_ALERT_USD=500
